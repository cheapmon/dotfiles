#!/usr/bin/env bash
set -euo pipefail

source "$(dirname "$0")/lib/zj-switch"

declare -a paths

# Get zoxide paths
mapfile -t paths < <(zoxide query --list 2>/dev/null || true)

if [[ ${#paths[@]} -eq 0 ]]; then
  echo "Error: No paths in zoxide history" >&2
  exit 1
fi

# Select path
path=$(printf '%s\n' "${paths[@]}" | sort | fzf --prompt "path " --preview "ls {}" --style full) || exit 0
app=$(basename "$path")

# Prompt for layout only if no existing session
layout=""
if ! zj_session_exists "$app"; then
  if ! zj_layouts | grep -q .; then
    echo "No zellij layouts found in ~/.config/zellij/layouts" >&2
    exit 1
  fi
  layout=$(zj_layouts | sort | fzf --prompt "layout " --style full) || exit 0
fi

zj_switch "$app" "$path" "$layout"
