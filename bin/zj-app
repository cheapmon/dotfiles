#!/usr/bin/env bash
set -euo pipefail

source "$(dirname "$0")/lib/zj-switch"

declare -a paths
declare -A apps

# Build apps list
paths+=(~/git/architecture)
if [[ -d ~/git/architecture/apps ]]; then
  for d in ~/git/architecture/apps/*; do
    [[ -d "$d" ]] && paths+=("$d")
  done
fi

for path in "${paths[@]}"; do
  b=$(basename "$path")
  apps[$b]=$path
done

# Select app
app=$(printf '%s\n' "${!apps[@]}" | sort | fzf --prompt "app " --style full) || exit 0
path="${apps[$app]}"

# Find matching layout
layout="app"
while IFS= read -r l; do
  [[ $l == "$app" ]] && layout=$l && break
done < <(zj_layouts)

zj_switch "$app" "$path" "$layout"
