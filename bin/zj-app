#!/usr/bin/env bash
set -euo pipefail

declare -a paths layouts sessions
declare -A apps

# Build apps list
paths+=(~/git/architecture)
if [[ -d ~/git/architecture/apps ]]; then
  for d in ~/git/architecture/apps/*; do
    [[ -d "$d" ]] && paths+=("$d")
  done
fi

for path in "${paths[@]}"; do
  b=$(basename "$path")
  apps[$b]=$path
done

# Get available layouts
for f in ~/.config/zellij/layouts/*.kdl; do
  [[ -f "$f" ]] && layouts+=("$(basename -s .kdl "$f")")
done

# Get active sessions
mapfile -t sessions < <(zellij ls -s 2>/dev/null || true)

# Select app
app=$(printf '%s\n' "${!apps[@]}" | sort | fzf --prompt "app " --style full) || exit 0
path="${apps[$app]}"

# Find matching layout
layout="app"
for l in "${layouts[@]}"; do
  [[ $l == "$app" ]] && layout=$l && break
done

# Check if session exists
session=""
for s in "${sessions[@]}"; do
  [[ $s == "$app" ]] && session=$s && break
done

if [[ -v ZELLIJ ]]; then
  if [[ -n "$session" ]]; then
    zellij pipe --plugin zellij-switch -- "--session ${app}"
  else
    zellij pipe --plugin zellij-switch -- "--session $app --cwd $path --layout $layout"
  fi
else
  if [[ -n "$session" ]]; then
    zellij attach "$app"
  else
    zellij --layout "$layout" attach -c "$app" options --default-cwd="$path"
  fi
fi
