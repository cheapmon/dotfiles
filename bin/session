#!/usr/bin/env bash
set -euo pipefail

declare -a paths layouts sessions

# Get zoxide paths
mapfile -t paths < <(zoxide query --list 2>/dev/null || true)

if [[ ${#paths[@]} -eq 0 ]]; then
  echo "Error: No paths in zoxide history" >&2
  exit 1
fi

# Get available layouts
for f in ~/.config/zellij/layouts/*.kdl; do
  [[ -f "$f" ]] && layouts+=("$(basename -s .kdl "$f")")
done

# Get active sessions
mapfile -t sessions < <(zellij ls -s 2>/dev/null || true)

# Select path
path=$(printf '%s\n' "${paths[@]}" | sort | fzf --prompt "path " --preview "ls {}" --style full) || exit 0
app=$(basename "$path")

# Check if session exists
session=""
for s in "${sessions[@]}"; do
  [[ $s == "$app" ]] && session=$s && break
done

if [[ -n "$session" ]]; then
  # Attach to existing session
  if [[ -v ZELLIJ ]]; then
    zellij pipe --plugin zellij-switch -- "--session ${app}"
  else
    zellij attach "$app"
  fi
else
  # Create new session - select layout
  layout=$(printf '%s\n' "${layouts[@]}" | sort | fzf --prompt "layout " --style full) || exit 0

  if [[ -v ZELLIJ ]]; then
    zellij pipe --plugin zellij-switch -- "--session $app --cwd $path --layout $layout"
  else
    zellij --layout "$layout" attach -c "$app" options --default-cwd="$path"
  fi
fi
